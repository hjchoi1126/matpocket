# Supabase 프로젝트 설정 (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 카카오 개발자 설정 (https://developers.kakao.com)
# REST API 키 / JavaScript 키는 반드시 같은 앱에서 발급받을 것 (맵 권한 있는 앱)
# REST API 키: 서버에서 맛집 검색 API 호출용 (클라이언트에 노출 금지)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
# JavaScript 키: 브라우저에서 카카오맵 SDK 로드용
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key

# OpenWeatherMap (선택) — 없으면 하드코딩 날씨로 동작
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
